{
  "name": "chat-mermaid",
  "version": "0.1.3",
  "description": "A plugin for @opencode-ai/plugin that renders Mermaid diagrams in chat responses",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "chat",
    "opencode",
    "plugin",
    "svg",
    "markdown"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ims-kdks/chat-mermaid.git"
  },
  "bugs": {
    "url": "https://github.com/ims-kdks/chat-mermaid/issues"
  },
  "homepage": "https://github.com/ims-kdks/chat-mermaid#readme",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.15",
    "@types/node": "^25.3.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "beautiful-mermaid": "^1.1.3"
  }
}
